# Скопируйте этот файл в .env и заполните значения.

# Пароль приложения в открытом виде. Это локальное приложение без доступа
# в интернет — хеширование только усложняет запуск.
APP_PASSWORD=change-me

# Секрет сессии (минимум 32 символа). Любая длинная случайная строка.
SESSION_SECRET=replace-with-a-long-random-string-of-at-least-32-chars

# Путь к SQLite. Внутри контейнера — /app/data/data.db
DATABASE_URL=file:./data/data.db

# Папка для сканов. Внутри контейнера — /app/uploads
UPLOADS_DIR=./uploads

# Максимальный размер одного загружаемого файла, МБ
MAX_UPLOAD_MB=10

# Включить secure-флаг на сессионной куке. По умолчанию false — для локального
# http-доступа. Установите true, только если приложение отдаётся по HTTPS.
COOKIE_SECURE=false
